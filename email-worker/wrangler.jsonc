{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "kudoso-email",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-07",
  "compatibility_flags": ["nodejs_compat"],
  "send_email": [
    {
      "name": "SEB"
    }
  ],
  "routes": [
    {
      "pattern": "email-worker.kudoso.io",
      "custom_domain": true
    }
  ]
}
