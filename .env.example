# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://kudoso.io

# ── Email ─────────────────────────────────────────────────────────────────────
# Display name + address for outbound emails (sent via CF email worker)
FROM_EMAIL="Kudoso <noreply@kudoso.io>"

# ── Anthropic (AI summaries + sentiment) ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Polar (billing) ───────────────────────────────────────────────────────────
# Environment: "sandbox" for testing, "production" for live
POLAR_ACCESS_TOKEN=polar_oat_...
POLAR_WEBHOOK_SECRET=polar_whs_...
POLAR_ENVIRONMENT=production
POLAR_SUCCESS_URL=https://kudoso.io/dashboard/billing?status=success

# ── Cloudflare ────────────────────────────────────────────────────────────────
# Shared Account ID (find at dash.cloudflare.com → right sidebar)
CLOUDFLARE_ACCOUNT_ID=

# R2 — static assets (logos)
# Create R2 API token: dash.cloudflare.com → My Profile → API Tokens → R2 Read+Write
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=kudoso-static
# Public bucket URL — enable in R2 bucket settings or use custom domain
CLOUDFLARE_R2_PUBLIC_URL=https://static.kudoso.io

# Stream — video hosting (testimonial videos)
# Create API token with Stream:Edit permission
CLOUDFLARE_STREAM_API_TOKEN=

# Email Worker — transactional email via MailChannels
# After: cd email-worker && wrangler deploy
CLOUDFLARE_EMAIL_WORKER_URL=https://kudoso-email.<your-subdomain>.workers.dev
# Set same value via: cd email-worker && wrangler secret put EMAIL_WORKER_SECRET
CLOUDFLARE_EMAIL_WORKER_SECRET=<random-32-char-string>
